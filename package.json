    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sendgrid": "^5.2.3",
    "sequelize": "^6.35.0",
